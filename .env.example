OLLAMA_MODEL=phi3
OLLAMA_ENABLED=true
LOG_MODE=local
SOC_HOST=192.168.231.128
SOC_USER=ubuntu
SOC_SURICATA_EVE=/var/log/suricata/eve.json
SOC_SURICATA_FAST=/var/log/suricata/fast.log
VICTIM_HOST=192.168.231.129
VICTIM_USER=ubuntu
VICTIM_APACHE_ACCESS=/var/log/apache2/access.log
VICTIM_APACHE_ERROR=/var/log/apache2/error.log
VICTIM_AUTH_LOG=/var/log/auth.log
VICTIM_SYSLOG=/var/log/syslog
# SSH_PASSWORD=
# SSH_KEY_PATH=C:\Users\vous\.ssh\id_ed25519
# PROJECT_ROOT=C:\SOC-AI-Agent
CORRELATION_WINDOW_MINUTES=10
SSH_TIMEOUT=10

# SIEM optionnel. Sans URL/token, les exports JSON de shared_logs/siem sont lus.
SIEM_ENABLED=true
# ELASTIC_URL=https://elastic.example:9200
ELASTIC_INDEX=logs-*,alerts-*
# ELASTIC_API_KEY=replace_me
# SPLUNK_URL=https://splunk.example:8089
# SPLUNK_TOKEN=replace_me
SPLUNK_SEARCH=search index=* (tag=attack OR sourcetype=suricata)
SIEM_VERIFY_SSL=true
